# ============================================================
# CREDENTIALS — never commit secrets
# ============================================================
# Generated by Terraform: kubeconfig + talosconfig
credentials/

# Talos raw machine configs (contain private keys / tokens)
talos/controlplane.yaml
talos/worker.yaml
talos/talosconfig

# ============================================================
# TERRAFORM
# ============================================================
**/.terraform/

*.tfstate
*.tfstate.*
*.tfvars.backup

# Crash log files
crash.log
crash.*.log

# Override files — local only
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files (may contain sensitive output)
*.tfplan

# ============================================================
# OS / EDITOR
# ============================================================
.DS_Store
.idea/
.vscode/settings.json
*.swp
*.swo

secrets/*.yaml
!secrets/*.sops.yaml

k8s-manifests/**/*.secret.yaml